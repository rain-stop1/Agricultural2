# 服务器配置
NODE_ENV=development
PORT=3001
HOST=localhost

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=agricultural_disaster_db
DB_USER=root
DB_PASSWORD=8022

# JWT配置
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random
JWT_EXPIRES_IN=24h

# 气象API配置 - OpenWeatherMap
# 获取免费API密钥: https://openweathermap.org/api
OPENWEATHER_API_KEY=d2d23ca63c7577486d01cda1125ea0ef
WEATHER_API_KEY=d2d23ca63c7577486d01cda1125ea0ef
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# 日志配置
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# 安全配置
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500

# AI模型配置
# OpenAI API密钥 - 获取地址: https://platform.openai.com/account/api-keys
# 如果不配置，系统会使用模拟回复
OPENAI_API_KEY=

# Qwen API密钥 - 获取地址: https://help.aliyun.com/document_detail/611472.html
# Qwen3.5-Plus API配置
QWEN_API_KEY=sk-abb13e034cab4317a9a3711f55683acd
QWEN_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
QWEN_MODEL=qwen-plus